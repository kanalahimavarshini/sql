SELECT EmployeeID,
       Name,
       Salary
FROM (
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER (
               ORDER BY Salary DESC
           ) AS SalaryRank
    FROM Employee
) t
WHERE SalaryRank = 4;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary IN (
    SELECT Salary
    FROM Employee
    WHERE DepartmentID = 3
);
SELECT ManagerID,
       AVG(Salary) AS AverageTeamSalary
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID;
SELECT ManagerID,
       AVG(Salary) AS AverageTeamSalary
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID
HAVING AVG(Salary) > 80000;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary % 5000 = 0;
SELECT
    YEAR(JoiningDate) AS HireYear,
    QUARTER(JoiningDate) AS HireQuarter,
    COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY YEAR(JoiningDate),
         QUARTER(JoiningDate)
ORDER BY HireYear, HireQuarter;
SELECT OrderID,
       CustomerID,
       OrderDate,
       OrderAmount
FROM (
    SELECT OrderID,
           CustomerID,
           OrderDate,
           OrderAmount,
           ROW_NUMBER() OVER (
               PARTITION BY CustomerID
               ORDER BY OrderDate
           ) AS rn
    FROM Orders
) t
WHERE rn = 1;
SELECT CustomerID,
       COUNT(DISTINCT OrderDate) AS DifferentOrderDates
FROM Orders
GROUP BY CustomerID
HAVING COUNT(DISTINCT OrderDate) > 3;
SELECT OrderID,
       CustomerID,
       OrderAmount
FROM (
    SELECT OrderID,
           CustomerID,
           OrderAmount,
           ROW_NUMBER() OVER (
               PARTITION BY CustomerID
               ORDER BY OrderAmount DESC
           ) AS rn
    FROM Orders
) t
WHERE rn = 1;
SELECT ProductID,
       SUM(Quantity * UnitPrice) AS TotalRevenue
FROM OrderDetails
GROUP BY ProductID
HAVING SUM(Quantity * UnitPrice) > 100000;
SELECT OrderID,
       CustomerID,
       OrderAmount,
       LEAD(OrderAmount) OVER (
           PARTITION BY CustomerID
           ORDER BY OrderDate
       ) - OrderAmount AS AmountDifference
FROM Orders;
SELECT *
FROM Employee e
WHERE 1 = (
    SELECT COUNT(*)
    FROM Employee e2
    WHERE e2.Email = e.Email
);
SELECT e.EmployeeID,
       e.Name,
       e.Salary,
       e.ManagerID
FROM Employee e
WHERE e.Salary > (
    SELECT AVG(t.Salary)
    FROM Employee t
    WHERE t.ManagerID = e.ManagerID
);
SELECT DepartmentID,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY DepartmentID
ORDER BY TotalEmployees DESC
LIMIT 1;
SELECT e.EmployeeID,
       e.Name
FROM Employee e
WHERE e.EmployeeID NOT IN (
    SELECT DISTINCT ManagerID
    FROM Employee
    WHERE ManagerID IS NOT NULL
);
SELECT e.EmployeeID,
       e.Name
FROM Employee e
LEFT JOIN Employee sub
ON e.EmployeeID = sub.ManagerID
WHERE sub.EmployeeID IS NULL;
SELECT DepartmentID,
       MAX(Salary) - MIN(Salary) AS SalaryDifference
FROM Employee
GROUP BY DepartmentID;
SELECT MONTH(JoiningDate) AS JoiningMonth,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY MONTH(JoiningDate)
HAVING COUNT(*) > 1;
WITH CustomerSpending AS (
    SELECT CustomerID,
           SUM(OrderAmount) AS TotalSpent
    FROM Orders
    GROUP BY CustomerID
)
SELECT CustomerID,
       TotalSpent
FROM CustomerSpending
WHERE TotalSpent > (
    SELECT AVG(TotalSpent)
    FROM CustomerSpending
);
SELECT CustomerID,
       MAX(OrderDate) AS LatestOrderDate
FROM Orders
GROUP BY CustomerID;
SELECT ProductID,
       ProductName,
       CategoryID,
       TotalQuantity
FROM (
    SELECT p.ProductID,
           p.ProductName,
           p.CategoryID,
           SUM(od.Quantity) AS TotalQuantity,
           DENSE_RANK() OVER (
               PARTITION BY p.CategoryID
               ORDER BY SUM(od.Quantity) DESC
           ) AS rn
    FROM Products p
    JOIN OrderDetails od
    ON p.ProductID = od.ProductID
    GROUP BY p.ProductID,
             p.ProductName,
             p.CategoryID
) t
WHERE rn = 1;