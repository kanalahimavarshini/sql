SELECT EmployeeID,
       Name,
       Salary
FROM (
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER (
               ORDER BY Salary DESC
           ) AS SalaryRank
    FROM Employee
) t
WHERE SalaryRank = 4;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary IN (
    SELECT Salary
    FROM Employee
    WHERE DepartmentID = 3
);
SELECT ManagerID,
       AVG(Salary) AS AverageTeamSalary
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID;
SELECT ManagerID,
       AVG(Salary) AS AverageTeamSalary
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID
HAVING AVG(Salary) > 80000;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary % 5000 = 0;
SELECT
    YEAR(JoiningDate) AS HireYear,
    QUARTER(JoiningDate) AS HireQuarter,
    COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY YEAR(JoiningDate),
         QUARTER(JoiningDate)
ORDER BY HireYear, HireQuarter;
SELECT OrderID,
       CustomerID,
       OrderDate,
       OrderAmount
FROM (
    SELECT OrderID,
           CustomerID,
           OrderDate,
           OrderAmount,
           ROW_NUMBER() OVER (
               PARTITION BY CustomerID
               ORDER BY OrderDate
           ) AS rn
    FROM Orders
) t
WHERE rn = 1;
SELECT CustomerID,
       COUNT(DISTINCT OrderDate) AS DifferentOrderDates
FROM Orders
GROUP BY CustomerID
HAVING COUNT(DISTINCT OrderDate) > 3;