SELECT EmployeeID,
       Name,
       Salary
FROM (
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER (
               ORDER BY Salary DESC
           ) AS SalaryRank
    FROM Employee
) t
WHERE SalaryRank = 4;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary IN (
    SELECT Salary
    FROM Employee
    WHERE DepartmentID = 3
);
SELECT ManagerID,
       AVG(Salary) AS AverageTeamSalary
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID;