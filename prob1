WHERE Department='IT'
);
SELECT *
FROM Student
WHERE Marks=
(
SELECT MAX(Marks)
FROM Student
);
SELECT Name,
Marks,
CASE
WHEN Marks>=90 THEN 'Excellent'
WHEN Marks>=75 THEN 'Good'
ELSE 'Average'
END AS Grade
FROM Student;
CREATE VIEW TopStudents AS
SELECT *
FROM Student
WHERE Marks>85;
CREATE INDEX idx_name
ON Student(Name);
CREATE TABLE Employee(
EmployeeID INT PRIMARY KEY,
Email VARCHAR(100) UNIQUE
);
CREATE TABLE Employee(
Age INT CHECK(Age>=18)
);
CREATE TABLE Employee(
Country VARCHAR(20)
