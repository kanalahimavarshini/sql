CREATE TRIGGER BeforeInsert
BEFORE INSERT
ON Student
FOR EACH ROW
SET NEW.Marks=IFNULL(NEW.Marks,0);
WITH HighMarks AS
(
SELECT *
FROM Student
WHERE Marks>85
)
SELECT *
FROM HighMarks;
SELECT
Name,
Marks,
ROW_NUMBER() OVER(ORDER BY Marks DESC) RankNo
FROM Student;
SELECT
Name,
Marks,
RANK() OVER(ORDER BY Marks DESC) RankNo
FROM Student;
SELECT
Name,
Marks,
DENSE_RANK() OVER(ORDER BY Marks DESC) RankNo
FROM Student;
SELECT
Name,
Marks,
LEAD(Marks) OVER(ORDER BY Marks) NextMarks
FROM Student;
SELECT
Name,
Marks,
LAG(Marks) OVER(ORDER BY Marks) PreviousMarks
FROM Student;
SELECT
Name,
FIRST_VALUE(Marks) OVER(ORDER BY Marks DESC) Highest
FROM Student;
SELECT
Name,
LAST_VALUE(Marks) OVER (
ORDER BY Marks
ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
) AS Lowest
FROM Student;
SELECT
Name,
Marks,
NTILE(4) OVER(ORDER BY Marks DESC) Quartile
FROM Student;
WITH RECURSIVE Numbers AS
(
SELECT 1 AS num
UNION ALL
SELECT num+1
FROM Numbers
WHERE num<10
)
SELECT * FROM Numbers;
