SELECT * FROM Student;
SELECT Name, Marks
FROM Student;
SELECT *
FROM Student
WHERE Marks > 80;
SELECT *
FROM Student
ORDER BY Marks DESC;
SELECT DISTINCT Department
FROM Student;
SELECT *
FROM Student
LIMIT 2;
UPDATE Student
SET Marks = 95
WHERE StudentID = 101;
DELETE FROM Student
WHERE StudentID = 103;
TRUNCATE TABLE Student;
DROP TABLE Student;
ALTER TABLE Student
