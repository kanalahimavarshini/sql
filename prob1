CREATE DATABASE CollegeDB;
USE CollegeDB;
CREATE TABLE Student(
    StudentID INT PRIMARY KEY,
    Name VARCHAR(50),
    Age INT,
    Department VARCHAR(30),
    Marks INT
);
INSERT INTO Student
VALUES
(101,'Alice',20,'CSE',90),
(102,'Bob',21,'ECE',85),
(103,'Charlie',22,'IT',78);
SELECT * FROM Student;
SELECT Name, Marks
FROM Student;
SELECT *
FROM Student
WHERE Marks > 80;
SELECT *
FROM Student
ORDER BY Marks DESC;
SELECT DISTINCT Department
FROM Student;
SELECT *
FROM Student
LIMIT 2;
UPDATE Student
SET Marks = 95
WHERE StudentID = 101;
DELETE FROM Student
WHERE StudentID = 103;
TRUNCATE TABLE Student;
DROP TABLE Student;
ALTER TABLE Student
ADD Email VARCHAR(50);
ALTER TABLE Student
RENAME COLUMN Name TO StudentName;
ALTER TABLE Student
MODIFY Age SMALLINT;
SELECT
COUNT(*) AS TotalStudents,
AVG(Marks) AS AverageMarks,
MAX(Marks) AS Highest,
MIN(Marks) AS Lowest,
SUM(Marks) AS TotalMarks
FROM Student;
SELECT Department,
AVG(Marks)
FROM Student
GROUP BY Department;
SELECT Department,
COUNT(*)
FROM Student
GROUP BY Department
HAVING COUNT(*) > 1;
SELECT *
FROM Student
WHERE Name LIKE 'A%';
SELECT *
FROM Student
WHERE Marks BETWEEN 80 AND 95;
SELECT *
FROM Student
WHERE Department IN ('CSE','IT');
SELECT *
FROM Student
WHERE Email IS NULL;
SELECT s.Name,d.DepartmentName
FROM Student s
INNER JOIN Department d
ON s.Department = d.DepartmentID;
SELECT s.Name,d.DepartmentName
FROM Student s
LEFT JOIN Department d
ON s.Department=d.DepartmentID;
SELECT s.Name,d.DepartmentName
FROM Student s
RIGHT JOIN Department d
ON s.Department=d.DepartmentID;