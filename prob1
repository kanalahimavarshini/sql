ALTER TABLE Student
RENAME COLUMN Name TO StudentName;
ALTER TABLE Student
MODIFY Age SMALLINT;
SELECT
COUNT(*) AS TotalStudents,
AVG(Marks) AS AverageMarks,
MAX(Marks) AS Highest,
MIN(Marks) AS Lowest,
SUM(Marks) AS TotalMarks
FROM Student;
SELECT Department,
AVG(Marks)
FROM Student
GROUP BY Department;
SELECT Department,
COUNT(*)
FROM Student
GROUP BY Department
HAVING COUNT(*) > 1;
SELECT *
FROM Student
WHERE Name LIKE 'A%';
SELECT *
FROM Student
WHERE Marks BETWEEN 80 AND 95;
SELECT *
FROM Student
WHERE Department IN ('CSE','IT');
SELECT *
FROM Student
WHERE Email IS NULL;
SELECT s.Name,d.DepartmentName
FROM Student s
INNER JOIN Department d
ON s.Department = d.DepartmentID;
SELECT s.Name,d.DepartmentName
FROM Student s
LEFT JOIN Department d
ON s.Department=d.DepartmentID;
SELECT s.Name,d.DepartmentName
FROM Student s
RIGHT JOIN Department d
ON s.Department=d.DepartmentID;
SELECT s.Name,d.DepartmentName
FROM Student s
FULL OUTER JOIN Department d
ON s.Department=d.DepartmentID;
SELECT *
FROM Student
CROSS JOIN Department;
SELECT A.Name,B.Name
FROM Employee A
JOIN Employee B
ON A.ManagerID=B.EmployeeID;
SELECT Name FROM Student
UNION
SELECT Name FROM Teacher;
SELECT Name FROM Student
UNION ALL
SELECT Name FROM Teacher;
SELECT *
FROM Student s
WHERE EXISTS
(
