SELECT *
FROM
(
    SELECT
        StudentID,
        Name,
        Department,
        Marks,
        ROW_NUMBER() OVER (
            PARTITION BY Department
            ORDER BY Marks DESC
        ) AS RankNo
    FROM Student
) AS RankedStudents
WHERE RankNo = 1;
