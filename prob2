SELECT JoiningDate,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY JoiningDate
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER(ORDER BY Salary DESC) AS RankNo
    FROM Employee
) t
WHERE RankNo = 3;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary,
       SUM(Salary) OVER(
           PARTITION BY DepartmentID
           ORDER BY EmployeeID
       ) AS CumulativeSalary
FROM Employee;
SELECT *
FROM Employee
WHERE EmployeeID % 2 = 0;
SELECT *
FROM Employee
WHERE EmployeeID % 2 <> 0;
SELECT COUNT(DISTINCT DepartmentID) AS TotalDepartments
FROM Employee;
SELECT EmployeeID,
       Name,
       CONCAT(
           LEFT(Name,1),
           '.'
       ) AS Initial
FROM Employee;
SELECT *
FROM Employee
WHERE Name LIKE '%RA%';