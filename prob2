SELECT JoiningDate,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY JoiningDate
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER(ORDER BY Salary DESC) AS RankNo
    FROM Employee
) t
WHERE RankNo = 3;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary,
       SUM(Salary) OVER(
           PARTITION BY DepartmentID
           ORDER BY EmployeeID
       ) AS CumulativeSalary
FROM Employee;
SELECT *
FROM Employee
WHERE EmployeeID % 2 = 0;
SELECT *
FROM Employee
WHERE EmployeeID % 2 <> 0;
SELECT COUNT(DISTINCT DepartmentID) AS TotalDepartments
FROM Employee;
SELECT EmployeeID,
       Name,
       CONCAT(
           LEFT(Name,1),
           '.'
       ) AS Initial
FROM Employee;
SELECT *
FROM Employee
WHERE Name LIKE '%RA%';
SELECT *
FROM Employee
WHERE JoiningDate < '2020-01-01';
SELECT *
FROM Employee
WHERE Salary % 1000 = 0;
SELECT YEAR(JoiningDate) AS Year,
       SUM(Salary) AS TotalSalary
FROM Employee
GROUP BY YEAR(JoiningDate)
ORDER BY Year;
SELECT
    ROW_NUMBER() OVER(ORDER BY EmployeeID) AS SerialNo,
    EmployeeID,
    Name,
    DepartmentID,
    Salary
FROM Employee;
SELECT *
FROM Employee
WHERE Salary = (
    SELECT MAX(Salary)
    FROM Employee
);
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary < (
    SELECT AVG(Salary)
    FROM Employee
);
SELECT EmployeeID,
       UPPER(Name) AS EmployeeName
FROM Employee;
SELECT EmployeeID,
       LOWER(Name) AS EmployeeName
FROM Employee;