SELECT JoiningDate,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY JoiningDate
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER(ORDER BY Salary DESC) AS RankNo
    FROM Employee
) t
WHERE RankNo = 3;