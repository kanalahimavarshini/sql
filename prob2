SELECT JoiningDate,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY JoiningDate
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER(ORDER BY Salary DESC) AS RankNo
    FROM Employee
) t
WHERE RankNo = 3;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary,
       SUM(Salary) OVER(
           PARTITION BY DepartmentID
           ORDER BY EmployeeID
       ) AS CumulativeSalary
FROM Employee;
SELECT *
FROM Employee
WHERE EmployeeID % 2 = 0;
SELECT *
FROM Employee
WHERE EmployeeID % 2 <> 0;
SELECT COUNT(DISTINCT DepartmentID) AS TotalDepartments
FROM Employee;
SELECT EmployeeID,
       Name,
       CONCAT(
           LEFT(Name,1),
           '.'
       ) AS Initial
FROM Employee;
SELECT *
FROM Employee
WHERE Name LIKE '%RA%';
SELECT *
FROM Employee
WHERE JoiningDate < '2020-01-01';
SELECT *
FROM Employee
WHERE Salary % 1000 = 0;
SELECT YEAR(JoiningDate) AS Year,
       SUM(Salary) AS TotalSalary
FROM Employee
GROUP BY YEAR(JoiningDate)
ORDER BY Year;
SELECT
    ROW_NUMBER() OVER(ORDER BY EmployeeID) AS SerialNo,
    EmployeeID,
    Name,
    DepartmentID,
    Salary
FROM Employee;
SELECT *
FROM Employee
WHERE Salary = (
    SELECT MAX(Salary)
    FROM Employee
);
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary < (
    SELECT AVG(Salary)
    FROM Employee
);
SELECT EmployeeID,
       UPPER(Name) AS EmployeeName
FROM Employee;
SELECT EmployeeID,
       LOWER(Name) AS EmployeeName
FROM Employee;
SELECT DepartmentID,
       Gender,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY DepartmentID, Gender
ORDER BY DepartmentID;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary
FROM Employee e
WHERE Salary = (
    SELECT AVG(Salary)
    FROM Employee
    WHERE DepartmentID = e.DepartmentID
);
SELECT CustomerID,
       COUNT(OrderID) AS TotalOrders,
       SUM(OrderAmount) AS TotalAmount
FROM Orders
GROUP BY CustomerID;
SELECT c.CustomerID,
       c.CustomerName
FROM Customers c
LEFT JOIN Orders o
ON c.CustomerID = o.CustomerID
WHERE o.OrderID IS NULL;
SELECT CustomerID,
       SUM(OrderAmount) AS TotalSpent
FROM Orders
GROUP BY CustomerID
ORDER BY TotalSpent DESC
LIMIT 5;
SELECT p.ProductID,
       p.ProductName
FROM Products p
LEFT JOIN OrderDetails od
ON p.ProductID = od.ProductID
WHERE od.ProductID IS NULL;
SELECT ProductID,
       SUM(Quantity) AS TotalSold
FROM OrderDetails
GROUP BY ProductID
ORDER BY TotalSold DESC
LIMIT 1;
SELECT ProductID,
       SUM(Quantity * UnitPrice) AS Revenue
FROM OrderDetails
GROUP BY ProductID
ORDER BY Revenue DESC;
SELECT CustomerID,
       SUM(OrderAmount) AS TotalSpent
FROM Orders
GROUP BY CustomerID
HAVING SUM(OrderAmount) > 50000;
SELECT ProductID,
       ProductName,
       Price
FROM Products
ORDER BY Price DESC
LIMIT 1;
SELECT ProductID,
       ProductName,
       Price
FROM Products
WHERE Price >
(
    SELECT AVG(Price)
    FROM Products
);
SELECT MONTH(OrderDate) AS OrderMonth,
       COUNT(*) AS TotalOrders
FROM Orders
GROUP BY MONTH(OrderDate)
ORDER BY OrderMonth;
SELECT CustomerID,
       COUNT(*) AS TotalOrders
FROM Orders
GROUP BY CustomerID
ORDER BY TotalOrders DESC
LIMIT 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           NTILE(10) OVER(ORDER BY Salary DESC) AS SalaryGroup
    FROM Employee
) t
WHERE SalaryGroup = 1;
SELECT CustomerID,
       AVG(OrderAmount) AS AverageOrderValue
FROM Orders
GROUP BY CustomerID;
SELECT ProductID,
       SUM(Quantity) AS TotalQuantity
FROM OrderDetails
GROUP BY ProductID
HAVING SUM(Quantity) > 100;
SELECT c.CustomerID,
       c.CustomerName,
       SUM(o.OrderAmount) AS TotalPurchase
FROM Customers c
JOIN Orders o
ON c.CustomerID = o.CustomerID
GROUP BY c.CustomerID, c.CustomerName;
SELECT EmployeeID,
       Name,
       JoiningDate
FROM Employee
WHERE DAYNAME(JoiningDate) = 'Monday';
SELECT EmployeeID,
       Name,
       DATEDIFF(CURDATE(), JoiningDate) AS DaysWorked
FROM Employee;