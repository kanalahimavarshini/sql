SELECT JoiningDate,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY JoiningDate
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           DENSE_RANK() OVER(ORDER BY Salary DESC) AS RankNo
    FROM Employee
) t
WHERE RankNo = 3;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary,
       SUM(Salary) OVER(
           PARTITION BY DepartmentID
           ORDER BY EmployeeID
       ) AS CumulativeSalary
FROM Employee;
SELECT *
FROM Employee
WHERE EmployeeID % 2 = 0;
SELECT *
FROM Employee
WHERE EmployeeID % 2 <> 0;
SELECT COUNT(DISTINCT DepartmentID) AS TotalDepartments
FROM Employee;
SELECT EmployeeID,
       Name,
       CONCAT(
           LEFT(Name,1),
           '.'
       ) AS Initial
FROM Employee;
SELECT *
FROM Employee
WHERE Name LIKE '%RA%';
SELECT *
FROM Employee
WHERE JoiningDate < '2020-01-01';
SELECT *
FROM Employee
WHERE Salary % 1000 = 0;
SELECT YEAR(JoiningDate) AS Year,
       SUM(Salary) AS TotalSalary
FROM Employee
GROUP BY YEAR(JoiningDate)
ORDER BY Year;
SELECT
    ROW_NUMBER() OVER(ORDER BY EmployeeID) AS SerialNo,
    EmployeeID,
    Name,
    DepartmentID,
    Salary
FROM Employee;
SELECT *
FROM Employee
WHERE Salary = (
    SELECT MAX(Salary)
    FROM Employee
);
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary < (
    SELECT AVG(Salary)
    FROM Employee
);
SELECT EmployeeID,
       UPPER(Name) AS EmployeeName
FROM Employee;
SELECT EmployeeID,
       LOWER(Name) AS EmployeeName
FROM Employee;
SELECT DepartmentID,
       Gender,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY DepartmentID, Gender
ORDER BY DepartmentID;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary
FROM Employee e
WHERE Salary = (
    SELECT AVG(Salary)
    FROM Employee
    WHERE DepartmentID = e.DepartmentID
);
SELECT CustomerID,
       COUNT(OrderID) AS TotalOrders,
       SUM(OrderAmount) AS TotalAmount
FROM Orders
GROUP BY CustomerID;
SELECT c.CustomerID,
       c.CustomerName
FROM Customers c
LEFT JOIN Orders o
ON c.CustomerID = o.CustomerID
WHERE o.OrderID IS NULL;
SELECT CustomerID,
       SUM(OrderAmount) AS TotalSpent
FROM Orders
GROUP BY CustomerID
ORDER BY TotalSpent DESC
LIMIT 5;
SELECT p.ProductID,
       p.ProductName
FROM Products p
LEFT JOIN OrderDetails od
ON p.ProductID = od.ProductID
WHERE od.ProductID IS NULL;
SELECT ProductID,
       SUM(Quantity) AS TotalSold
FROM OrderDetails
GROUP BY ProductID
ORDER BY TotalSold DESC
LIMIT 1;
SELECT ProductID,
       SUM(Quantity * UnitPrice) AS Revenue
FROM OrderDetails
GROUP BY ProductID
ORDER BY Revenue DESC;
SELECT CustomerID,
       SUM(OrderAmount) AS TotalSpent
FROM Orders
GROUP BY CustomerID
HAVING SUM(OrderAmount) > 50000;
SELECT ProductID,
       ProductName,
       Price
FROM Products
ORDER BY Price DESC
LIMIT 1;
SELECT ProductID,
       ProductName,
       Price
FROM Products
WHERE Price >
(
    SELECT AVG(Price)
    FROM Products
);
SELECT MONTH(OrderDate) AS OrderMonth,
       COUNT(*) AS TotalOrders
FROM Orders
GROUP BY MONTH(OrderDate)
ORDER BY OrderMonth;
SELECT CustomerID,
       COUNT(*) AS TotalOrders
FROM Orders
GROUP BY CustomerID
ORDER BY TotalOrders DESC
LIMIT 1;
SELECT EmployeeID,
       Name,
       Salary
FROM
(
    SELECT EmployeeID,
           Name,
           Salary,
           NTILE(10) OVER(ORDER BY Salary DESC) AS SalaryGroup
    FROM Employee
) t
WHERE SalaryGroup = 1;
SELECT CustomerID,
       AVG(OrderAmount) AS AverageOrderValue
FROM Orders
GROUP BY CustomerID;
SELECT ProductID,
       SUM(Quantity) AS TotalQuantity
FROM OrderDetails
GROUP BY ProductID
HAVING SUM(Quantity) > 100;
SELECT c.CustomerID,
       c.CustomerName,
       SUM(o.OrderAmount) AS TotalPurchase
FROM Customers c
JOIN Orders o
ON c.CustomerID = o.CustomerID
GROUP BY c.CustomerID, c.CustomerName;
SELECT EmployeeID,
       Name,
       JoiningDate
FROM Employee
WHERE DAYNAME(JoiningDate) = 'Monday';
SELECT EmployeeID,
       Name,
       DATEDIFF(CURDATE(), JoiningDate) AS DaysWorked
FROM Employee;
SELECT DepartmentID,
       AVG(Salary) AS AverageSalary
FROM Employee
GROUP BY DepartmentID
HAVING AVG(Salary) > 75000;
SELECT e1.EmployeeID,
       e1.Name,
       e1.DepartmentID,
       e1.Salary
FROM Employee e1
JOIN Employee e2
ON e1.DepartmentID = e2.DepartmentID
AND e1.Salary = e2.Salary
AND e1.EmployeeID <> e2.EmployeeID
ORDER BY e1.DepartmentID;
SELECT MIN(Salary) AS SecondLowestSalary
FROM Employee
WHERE Salary >
(
    SELECT MIN(Salary)
    FROM Employee
);
SELECT EmployeeID,
       Name,
       Salary,
       LAG(Salary) OVER(ORDER BY EmployeeID) AS PreviousSalary,
       ROUND(
           ((Salary - LAG(Salary) OVER(ORDER BY EmployeeID))
           / LAG(Salary) OVER(ORDER BY EmployeeID)) * 100,
           2
       ) AS PercentageIncrease
FROM Employee;
SELECT e1.EmployeeID,
       e2.EmployeeID AS NextEmployeeID
FROM Employee e1
JOIN Employee e2
ON e1.EmployeeID + 1 = e2.EmployeeID;
SELECT EmployeeID,
       Name,
       LENGTH(Name) AS NameLength
FROM Employee
ORDER BY LENGTH(Name) DESC;
SELECT DepartmentID,
       SUM(Salary) AS TotalSalary
FROM Employee
GROUP BY DepartmentID
ORDER BY TotalSalary DESC
LIMIT 1;
SELECT Email,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY Email
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary,
       CASE
           WHEN Salary >= 100000 THEN 'High'
           WHEN Salary >= 50000 THEN 'Medium'
           ELSE 'Low'
       END AS SalaryCategory
FROM Employee;
SELECT EmployeeID,
       Name,
       JoiningDate,
       DATEDIFF(CURDATE(), JoiningDate) AS TotalDays
FROM Employee
ORDER BY TotalDays DESC
LIMIT 1;
SELECT EmployeeID,
       Name,
       DepartmentID
FROM Employee
ORDER BY DepartmentID, Name;
SELECT YEAR(OrderDate) AS Year,
       MONTH(OrderDate) AS Month,
       SUM(OrderAmount) AS Revenue
FROM Orders
GROUP BY YEAR(OrderDate), MONTH(OrderDate)
ORDER BY Year, Month;
SELECT CustomerID
FROM Orders
GROUP BY CustomerID
HAVING COUNT(DISTINCT MONTH(OrderDate)) = 12;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary > ALL
(
    SELECT Salary
    FROM Employee
    WHERE DepartmentID = 2
);
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary = ANY
(
    SELECT Salary
    FROM Employee
    WHERE DepartmentID = 1
);
SELECT *
FROM Employee
WHERE DepartmentID =
(
    SELECT DepartmentID
    FROM Employee
    WHERE Name = 'John'
);
SELECT AVG(Salary) AS AverageSalary
FROM Employee
WHERE Salary <
(
    SELECT MAX(Salary)
    FROM Employee
);
SELECT EmployeeID,
       Name,
       BirthDate,
       TIMESTAMPDIFF(YEAR, BirthDate, CURDATE()) AS Age
FROM Employee;
SELECT EmployeeID,
       Name,
       BirthDate
FROM Employee
WHERE MONTH(BirthDate) = MONTH(CURDATE())
AND DAY(BirthDate) = DAY(CURDATE());
SELECT MONTH(JoiningDate) AS Month,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY MONTH(JoiningDate)
ORDER BY Month;
SELECT ProductID,
       COUNT(*) AS OrderCount
FROM OrderDetails
GROUP BY ProductID
ORDER BY OrderCount DESC
LIMIT 1;
SELECT CustomerID,
       COUNT(DISTINCT ProductID) AS ProductCount
FROM OrderDetails
GROUP BY CustomerID
HAVING COUNT(DISTINCT ProductID) > 1;
SELECT YEAR(OrderDate) AS Year,
       MONTH(OrderDate) AS Month,
       AVG(OrderAmount) AS AverageOrderValue
FROM Orders
GROUP BY YEAR(OrderDate), MONTH(OrderDate)
ORDER BY Year, Month;
SELECT EmployeeID,
       Name
FROM Employee
WHERE ManagerID IS NULL;
SELECT DepartmentID,
       AVG(Salary) AS AverageSalary
FROM Employee
GROUP BY DepartmentID
ORDER BY AverageSalary DESC
LIMIT 1;
SELECT e.EmployeeID,
       e.Name,
       e.DepartmentID,
       e.Salary
FROM Employee e
WHERE e.Salary >
(
    SELECT MAX(e2.Salary)
    FROM Employee e2
    WHERE e2.DepartmentID <> e.DepartmentID
);
WITH SalaryChanges AS
(
    SELECT
        EmployeeID,
        Name,
        Salary,
        Salary - LAG(Salary) OVER(ORDER BY EmployeeID) AS SalaryIncrease
    FROM Employee
)
SELECT EmployeeID,
       Name,
       Salary,
       SalaryIncrease
FROM SalaryChanges
WHERE SalaryIncrease =
(
    SELECT MAX(SalaryIncrease)
    FROM SalaryChanges
);
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary
FROM (
    SELECT EmployeeID,
           Name,
           DepartmentID,
           Salary,
           DENSE_RANK() OVER (
               PARTITION BY DepartmentID
               ORDER BY Salary DESC
           ) AS RankNo
    FROM Employee
) AS RankedEmployees
WHERE RankNo = 2;
SELECT ManagerID,
       COUNT(*) AS EmployeeCount
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID
HAVING COUNT(*) > 1;
SELECT ManagerID,
       COUNT(*) AS TeamSize
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID
HAVING COUNT(*) > 5;
SELECT Salary,
       COUNT(*) AS Frequency
FROM Employee
GROUP BY Salary
ORDER BY Frequency DESC
LIMIT 1;
SELECT EmployeeID,
       Name,
       Salary
FROM Employee
WHERE Salary BETWEEN 50000 AND 100000;
SELECT DepartmentID,
       COUNT(*) AS EmployeeCount,
       ROUND(
           COUNT(*) * 100.0 / SUM(COUNT(*)) OVER(),
           2
       ) AS Percentage
FROM Employee
GROUP BY DepartmentID;
SELECT DepartmentID,
       MIN(JoiningDate) AS FirstJoiningDate,
       MAX(JoiningDate) AS LastJoiningDate
FROM Employee
GROUP BY DepartmentID;
SELECT EmployeeID,
       Name,
       JoiningDate
FROM Employee
WHERE JoiningDate BETWEEN '2022-01-01' AND '2023-12-31';
SELECT OrderID,
       CustomerID,
       OrderAmount
FROM Orders
WHERE OrderAmount > (
    SELECT AVG(OrderAmount)
    FROM Orders
);
SELECT ProductID,
       ProductName,
       Price
FROM (
    SELECT ProductID,
           ProductName,
           Price,
           DENSE_RANK() OVER (
               ORDER BY Price DESC
           ) AS PriceRank
    FROM Products
) AS RankedProducts
WHERE PriceRank = 2;
SELECT CustomerID,
       COUNT(OrderID) AS TotalOrders
FROM Orders
GROUP BY CustomerID
HAVING COUNT(OrderID) >= 3;
SELECT YEAR(OrderDate) AS OrderYear,
       MONTH(OrderDate) AS OrderMonth,
       SUM(OrderAmount) AS TotalRevenue
FROM Orders
GROUP BY YEAR(OrderDate), MONTH(OrderDate)
ORDER BY TotalRevenue DESC
LIMIT 1;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary
FROM Employee e
WHERE Salary > (
    SELECT AVG(Salary)
    FROM Employee
    WHERE DepartmentID = e.DepartmentID
);
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary
FROM (
    SELECT EmployeeID,
           Name,
           DepartmentID,
           Salary,
           DENSE_RANK() OVER (
               PARTITION BY DepartmentID
               ORDER BY Salary DESC
           ) AS RankNo
    FROM Employee
) AS RankedEmployees
WHERE RankNo = 3;
SELECT EmployeeID,
       Name
FROM Employee
WHERE LENGTH(Name) > 5;
SELECT EmployeeID,
       Name
FROM Employee
WHERE LOWER(LEFT(Name, 1)) =
      LOWER(RIGHT(Name, 1));
      SELECT ManagerID,
       COUNT(*) AS TotalEmployees
FROM Employee
WHERE ManagerID IS NOT NULL
GROUP BY ManagerID;
SELECT e.Name AS EmployeeName,
       e.JoiningDate AS EmployeeJoiningDate,
       m.Name AS ManagerName,
       m.JoiningDate AS ManagerJoiningDate
FROM Employee e
JOIN Employee m
ON e.ManagerID = m.EmployeeID
WHERE e.JoiningDate < m.JoiningDate;
SELECT DISTINCT
       DepartmentID,
       FIRST_VALUE(Name) OVER (
           PARTITION BY DepartmentID
           ORDER BY Salary DESC
       ) AS HighestPaidEmployee
FROM Employee;
SELECT EmployeeID,
       Name,
       Salary,
       MAX(Salary) OVER() - Salary AS Difference
FROM Employee;
SELECT ProductID,
       ProductName,
       CategoryID,
       Revenue
FROM (
    SELECT ProductID,
           ProductName,
           CategoryID,
           SUM(Quantity * UnitPrice) AS Revenue,
           DENSE_RANK() OVER (
               PARTITION BY CategoryID
               ORDER BY SUM(Quantity * UnitPrice) DESC
           ) AS RankNo
    FROM OrderDetails
    GROUP BY ProductID,
             ProductName,
             CategoryID
) AS RankedProducts
WHERE RankNo <= 2;
WITH MonthlyRevenue AS (
    SELECT
        YEAR(OrderDate) AS OrderYear,
        MONTH(OrderDate) AS OrderMonth,
        SUM(OrderAmount) AS Revenue
    FROM Orders
    GROUP BY YEAR(OrderDate),
             MONTH(OrderDate)
)
SELECT
    OrderYear,
    OrderMonth,
    Revenue,
    LAG(Revenue) OVER (
        ORDER BY OrderYear, OrderMonth
    ) AS PreviousRevenue,
    Revenue - LAG(Revenue) OVER (
        ORDER BY OrderYear, OrderMonth
    ) AS RevenueGrowth
FROM MonthlyRevenue;
SELECT CustomerID
FROM Orders
WHERE ProductID IN (
    SELECT ProductID
    FROM Products
    WHERE CategoryID = 1
)
GROUP BY CustomerID
HAVING COUNT(DISTINCT ProductID) = (
    SELECT COUNT(*)
    FROM Products
    WHERE CategoryID = 1
);
SELECT Name,
       DepartmentID,
       Salary,
       COUNT(*) AS DuplicateCount
FROM Employee
GROUP BY Name,
         DepartmentID,
         Salary
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       DepartmentID,
       Salary
FROM (
    SELECT EmployeeID,
           Name,
           DepartmentID,
           Salary,
           ROW_NUMBER() OVER (
               PARTITION BY DepartmentID
               ORDER BY Salary DESC
           ) AS rn
    FROM Employee
) t
WHERE rn = 1;
SELECT e.EmployeeID,
       e.Name AS EmployeeName,
       e.Salary,
       m.Name AS ManagerName
FROM Employee e
JOIN Employee m
ON e.ManagerID = m.EmployeeID
WHERE e.Salary = m.Salary;
SELECT Name,
       COUNT(*) AS TotalEmployees
FROM Employee
GROUP BY Name
HAVING COUNT(*) > 1;
SELECT EmployeeID,
       Name,
       Salary,
       Salary - LAG(Salary) OVER (
           ORDER BY EmployeeID
       ) AS SalaryDifference
FROM Employee;
SELECT *
FROM Employee
WHERE DepartmentID IN (
    SELECT DepartmentID
    FROM Employee
    GROUP BY DepartmentID
    HAVING COUNT(*) > 3
);
SELECT OrderID,
       CustomerID,
       OrderDate,
       OrderAmount
FROM (
    SELECT OrderID,
           CustomerID,
           OrderDate,
           OrderAmount,
           ROW_NUMBER() OVER (
               PARTITION BY CustomerID
               ORDER BY OrderDate DESC
           ) AS rn
    FROM Orders
) t
WHERE rn = 1;
SELECT CustomerID,
       MIN(OrderDate) AS FirstOrderDate
FROM Orders
GROUP BY CustomerID;
SELECT CustomerID,
       MAX(OrderDate) AS LastOrderDate
FROM Orders
GROUP BY CustomerID;
SELECT ProductID,
       ProductName,
       CategoryID,
       Price
FROM Products p
WHERE Price > (
    SELECT AVG(Price)
    FROM Products
    WHERE CategoryID = p.CategoryID
);
SELECT CustomerID,
       SUM(OrderAmount) AS TotalRevenue
FROM Orders
GROUP BY CustomerID
ORDER BY TotalRevenue DESC;
SELECT OrderID,
       CustomerID,
       OrderDate,
       COUNT(*) OVER (
           PARTITION BY CustomerID
           ORDER BY OrderDate
       ) AS RunningOrderCount
FROM Orders;